# OpenZiti admin credentials
ZITI_USER=admin
ZITI_PWD=CHANGE_ME

# Email for Let's Encrypt notifications (used by Caddy)
CADDY_EMAIL=you@example.com
CADDY_DOMAIN=your.domain.example.com

# Basic auth gate in front of ZAC
# Generate hash: docker run --rm caddy:2 caddy hash-password --plaintext "tu-contraseña"
CADDY_BASIC_USER=admin
CADDY_BASIC_HASH=GENERATED_HASH_HERE

# Network interface to bind ports on (0.0.0.0 = all interfaces)
ZITI_INTERFACE=0.0.0.0

# Public address of the controller (fabric + edge API, single port)
ZITI_CTRL_ADVERTISED_ADDRESS=your.domain.example.com
ZITI_CTRL_ADVERTISED_PORT=38440

# Public address of the edge router
ZITI_ROUTER_ADVERTISED_ADDRESS=your.domain.example.com
ZITI_ROUTER_PORT=38442

# Enrollment period duration for identities and routers (in minutes)
# 10080 = 7 days
ZITI_EDGE_IDENTITY_ENROLLMENT_DURATION=10080
ZITI_ROUTER_ENROLLMENT_DURATION=10080

# Internal controller URL used by the ZAC console
# ZAC backend connects to controller internally (Docker hostname)
ZAC_CONTROLLER_URLS=https://ziti-controller:38440

# Bootstrap flags for the controller
ZITI_BOOTSTRAP=true
ZITI_BOOTSTRAP_PKI=true
ZITI_BOOTSTRAP_CONFIG=true
ZITI_BOOTSTRAP_DATABASE=true
ZITI_BOOTSTRAP_CLUSTER=true
ZITI_CLUSTER_TRUST_DOMAIN=ziti
ZITI_CLUSTER_NODE_NAME=ziti-controller1
ZITI_AUTO_RENEW_CERTS=true

# Edge router enrollment JWT.
# Leave empty on first deploy. Once the controller is healthy,
# get the JWT from ZAC → Routers → New Router, paste it here and bring up the stack.
ZITI_ENROLL_TOKEN=
